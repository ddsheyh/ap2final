{
  "id": null,
  "uid": "goticket-main",
  "title": "GoTicket — Microservices Overview",
  "tags": ["goticket"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Gateway — Total Requests",
      "type": "stat",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gateway_requests_total",
          "legendFormat": "Requests"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "thresholds": {"steps": [{"color": "green", "value": null}]}
        }
      }
    },
    {
      "id": 2,
      "title": "Gateway — Total Errors",
      "type": "stat",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gateway_errors_total",
          "legendFormat": "Errors"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 20}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Gateway — UP Status",
      "type": "stat",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "gateway_up",
          "legendFormat": "Gateway"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "mappings": [
          {"type": "value", "options": {"1": {"text": "UP", "color": "green"}, "0": {"text": "DOWN", "color": "red"}}}
        ]
      }
    },
    {
      "id": 4,
      "title": "Prometheus — Self UP",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "up",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "mappings": [
          {"type": "value", "options": {"1": {"text": "UP", "color": "green"}, "0": {"text": "DOWN", "color": "red"}}}
        ]
      }
    },
    {
      "id": 5,
      "title": "Requests Over Time",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(gateway_requests_total[1m])",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    },
    {
      "id": 6,
      "title": "Errors Over Time",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(gateway_errors_total[1m])",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      }
    }
  ]
}
